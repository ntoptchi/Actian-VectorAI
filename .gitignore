# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------- Python ----------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ---------- Node / Frontend ----------
node_modules/
.pnp
.pnp.js
coverage/
.next/
out/
next-env.d.ts
build/
*.tsbuildinfo

# nested project build output / deps (e.g. routewise/.next, routewise/node_modules)
**/node_modules/
**/.next/
**/out/
**/build/
**/coverage/

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Database (Next.js scaffold leftovers) ----------
/prisma/db.sqlite
/prisma/db.sqlite-journal
db.sqlite

# ---------- Local map stack (OSRM + tileserver-gl) ----------
osrm-data/
tiles-data/
# Repo-local binaries installed by scripts/setup_local_map.sh
# (currently just the go-pmtiles CLI).
.bin/

# ---------- Actian VectorAI DB ----------
# Docker volume mount with collection data. Too big for git (~1 GB for
# routewise_crashes alone); teammates fetch a pre-built snapshot via
# scripts/fetch_vdb_snapshot.py (pointer committed in vdb_snapshot.manifest.json).
vectorai-db-beta/data/
vectorai-db-beta/data/vde.log
# Heavyweight tarballs of the DB image
Actian_VectorAI_DB_Beta.tar
# Transient download artifact from scripts/fetch_vdb_snapshot.py — we delete
# it on success/failure, but list it here so a Ctrl+C mid-download doesn't
# accidentally land a 400 MB blob in `git add .`.
/vdb_snapshot.tar.gz

# ---------- RouteWise data + caches ----------
# data/raw/ IS committed — install.sh assumes the FDOT crash chunks, the
# AADT shapefile bundle, and the TDA CSVs are present so a fresh clone
# can seed the VDB without re-downloading anything. Total is ~213 MB.
# data/interim/, data/processed/, data/cache/ are all generated artifacts
# (parquet rollups, /trip/brief response cache) — install.sh + the running
# backend rebuild them, so we never want them in git.
data/interim/
data/processed/
data/cache/
.cache/
*.parquet
*.feather

# ---------- Models ----------
# NOTE: models/all-MiniLM-L6-v2/ is intentionally tracked (bundled offline).
# Anything else under models/ is treated as scratch.
models/*/
!models/all-MiniLM-L6-v2/
!models/README.md

# ---------- Scraper Data ----------
# all data is alr in the /data folder
scraper/data/

# ---------- Env ----------
# do not commit any .env files to git, except for the .env.example file
.env
.env.*
!.env.example
!**/.env.example

# ---------- Misc ----------
.DS_Store
Thumbs.db
*.pem
*.log

# ---------- Vercel ----------
.vercel

# ---------- IDE ----------
.idea/
.vscode/
*.swp
*.swo
