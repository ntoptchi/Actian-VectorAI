# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------- Python ----------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ---------- Node / Frontend ----------
node_modules/
.pnp
.pnp.js
/coverage
/.next/
/out/
next-env.d.ts
/build
*.tsbuildinfo

# nested project node_modules (e.g. routewise/node_modules)
**/node_modules/

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Database (Next.js scaffold leftovers) ----------
/prisma/db.sqlite
/prisma/db.sqlite-journal
db.sqlite

# ---------- Actian VectorAI DB ----------
# Docker volume mount with collection data
vectorai-db-beta/data/
# Heavyweight tarballs of the DB image
vectorai-db-beta/*.tar
Actian_VectorAI_DB_Beta.tar

# ---------- RouteWise data + caches ----------
# Raw downloads (FARS / CISS / FDOT crash exports / AADT shapefile)
data/raw/
data/interim/
data/processed/
# Pre-cached /trip/brief responses for the demo (kept out unless we deliberately commit a small subset)
data/cache/
.cache/
*.parquet
*.feather

# ---------- Models ----------
# NOTE: models/all-MiniLM-L6-v2/ is intentionally tracked (bundled offline).
# Anything else under models/ is treated as scratch.
models/*/
!models/all-MiniLM-L6-v2/
!models/README.md

# ---------- Env ----------
# do not commit any .env files to git, except for the .env.example file
.env
.env.*
!.env.example
!**/.env.example

# ---------- Misc ----------
.DS_Store
Thumbs.db
*.pem
*.log

# ---------- Vercel ----------
.vercel

# ---------- IDE ----------
.idea/
.vscode/
*.swp
*.swo
