# Brave Search API key. Get one at https://api.search.brave.com/
BRAVE_API_KEY=

# Optional override for Brave request rate (requests/sec).
# Default 20.0 (safe for Data-for-Search paid plan which allows up to 50 rps).
# Set to 1.0 if you are on the Brave free tier.
# BRAVE_RPS=20.0

# Optional Decodo/SmartProxy creds for article fetch rotation (same pattern
# as accscent/scraper/py/.env). Leave blank to fetch directly.
# SMART_PROXY_USER=
# SMART_PROXY_PASS=
