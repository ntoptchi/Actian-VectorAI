VECTORAI_HOST=localhost:50051

# Leave unset to use the repo-bundled model at ../models/all-MiniLM-L6-v2/.
# Override with a HF Hub slug (e.g. sentence-transformers/all-MiniLM-L6-v2)
# or an absolute path to a different local checkpoint.
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

USE_MOCK_EMBEDDINGS=false

Z_THRESHOLD=3.0
INCIDENT_TOP_K=3
MANUAL_TOP_K=3
CHUNK_TOP_K=2
